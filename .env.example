# =============================================
# AI Wine Sommelier - 환경변수 설정 예시
# 이 파일을 복사해서 .env 로 이름을 바꾸고 값을 채워주세요
# cp .env.example .env
# =============================================

# PostgreSQL 연결 문자열
# 로컬: postgresql://postgres:비밀번호@localhost:5432/wine_sommelier
# Railway DB 직접 연결: Railway 대시보드 > Postgres > Variables > DATABASE_PUBLIC_URL
DATABASE_URL=postgresql://postgres:password@localhost:5432/wine_sommelier

# OpenAI API 키 (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-proj-...

# 세션 암호화 키 (임의의 긴 문자열, 아래 명령어로 생성 가능)
# openssl rand -hex 32
SESSION_SECRET=your-secret-key-here

# 서버 포트 (기본값 5000, 선택사항)
# PORT=5000
